DATABASE_URL="postgresql://postgres:password@localhost:5432/it_ticketing"

# Must be at least 32 characters. Generate: openssl rand -base64 48
SESSION_SECRET="change-this-to-a-long-random-secret-min-32-chars"

# hCaptcha keys. For local dev you can use the official test pair:
#   site key: 10000000-ffff-ffff-ffff-000000000001
#   secret:   0x0000000000000000000000000000000000000000
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000001"
HCAPTCHA_SECRET="0x0000000000000000000000000000000000000000"

# SMTP for notifications. For local dev with Mailpit (docker compose):
#   SMTP_HOST=localhost SMTP_PORT=1025 SMTP_USER=dev SMTP_PASS=dev
# For production (Brevo):
#   SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587
#   SMTP_USER=<your-brevo-login> SMTP_PASS=<your-brevo-smtp-key>
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="IT Ticketing <no-reply@example.com>"
